# Copy this file to `.env` and fill in real values from the Firebase Console.
# Project settings -> General -> Your apps -> Web app -> SDK setup and configuration.
# .env is gitignored — never commit real keys.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# OAuth Web Client ID for Google Sign-In (from Google Cloud Console,
# or the "Web client (auto created by Google Service)" entry under
# APIs & Services -> Credentials, created automatically once you enable
# Google as a sign-in provider in Firebase Auth).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# iOS-specific OAuth client ID, needed for native Google Sign-In on iOS.
# Found in the same Credentials page, or in GoogleService-Info.plist as CLIENT_ID.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Android-specific OAuth client ID (SHA-1 fingerprint must be registered
# in Firebase Console -> Project settings -> Your apps -> Android app).
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
